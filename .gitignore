# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# Generated products (never versioned)
*_RELEASE.xlsx
*_DRAFT.xlsx
out.xlsx
extraction.xlsx
extraction.db
workspace/

# Real inputs — copyright / PHI safe. Only the SYNTHETIC corpus is versioned.
