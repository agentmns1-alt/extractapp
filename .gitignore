real_pdfs/

# Model / VLM responses (non-deterministic, may contain keys)
*.vlm.json
.cache/vlm/
*.response.json

# Optional binaries / language data (never a hard dep, never committed)
tesseract/
*.traineddata

# OS / editor
.DS_Store
Thumbs.db
*.swp
